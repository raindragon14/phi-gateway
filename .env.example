# ─────────────────────────────────────────────────────────────────
# Phi AI Gateway — Environment Configuration
# ─────────────────────────────────────────────────────────────────
#
# SELF-HOSTED (open source):
#   You MUST provide your OWN provider API keys below.
#   The gateway does NOT ship with any keys — you pay your own bills.
#
# PHI CONSULTING CLOUD (hosted product):
#   Provider keys are managed by the platform.
#   Visit https://phiconsulting.biz.id to sign up.
# ─────────────────────────────────────────────────────────────────

# Database (SQLite for local dev; use PostgreSQL in production)
DATABASE_URL=sqlite+aiosqlite:///data/phi.db

# ── LLM Providers ────────────────────────────────────────────────
# At least ONE provider must be configured for chat completions.
# Embeddings use OpenRouter (OPENROUTER_API_KEY) by default.
# See docs for each provider's sign-up and billing.
#
# IMPORTANT: These keys are NEVER exposed to end users.
# API consumers only need a gateway API key (see /v1/keys).

OPENAI_API_KEY=sk-your-openai-key-here             # https://platform.openai.com/api-keys (optional — chat only)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here   # https://console.anthropic.com/keys (optional)
GROQ_API_KEY=gsk_your-groq-key-here                # https://console.groq.com/keys (optional)
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key    # https://openrouter.ai/keys (required for embeddings, optional for chat)

# ── App ──────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
# APP_ROOT=/app    # Set in Docker container; auto-detected for local dev

# ── Security ────────────────────────────────────────────────────
# Set on first deploy to seed the initial admin API key.
# This key can create other keys; remove or comment out after bootstrapping.
# INITIAL_ADMIN_KEY=phi-sk-your-initial-admin-key-here
