# ─────────────────────────────────────────────────────
# PhiGateway — Environment Configuration
# ─────────────────────────────────────────────────────

# Database
# SQLite (default, zero config) or PostgreSQL for production.
DATABASE_URL=sqlite+aiosqlite:///data/phi.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/phi_gateway

# ── LLM Providers ───────────────────────────────────
# At least one provider key is required for chat completions.
# Embeddings require OPENROUTER_API_KEY.
# Keys are never exposed to API consumers (they use gateway keys via /v1/keys).

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# ── App ─────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
# APP_ROOT=/app           # Set automatically in Docker

# ── Security ────────────────────────────────────────
# Seeds an initial admin key on first boot (phi-sk-... format).
# Remove after bootstrapping — admin keys persist in the database.
# INITIAL_ADMIN_KEY=
